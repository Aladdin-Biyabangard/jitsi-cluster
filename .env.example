# ============================================================
# jitsi-deploy — minimum .env, sonra: ./deploy.sh
# ============================================================

# --- MƏCBURİ ---
GCP_PROJECT_ID=your-gcp-project-id
DOMAIN=meet.ingress.academy
ADMIN_EMAIL=admin@ingress.academy

# --- Bunny Stream (Ingress portal ilə eyni) ---
# Stream → Library → API access information
# Lazım olanlar:
#   Video library ID  → BUNNY_LIBRARY_ID
#   API Key           → BUNNY_API_KEY  (Read-only DEYİL)
# Optional:
#   CDN hostname      → BUNNY_CDN_HOSTNAME  (məs. vz-xxx.b-cdn.net)
# Lazım DEYİL: Read-only API Key, Pull zone adı
BUNNY_LIBRARY_ID=692053
BUNNY_API_KEY=your-stream-api-key
# BUNNY_CDN_HOSTNAME=vz-3167b49e-cb0.b-cdn.net

# --- GCP (default kifayətdir) ---
# GCP_REGION=europe-west1
# GCP_ZONE=europe-west1-b
# GCP_NETWORK=default

# --- Schedule (VM start/stop, xərc qənaəti) ---
# ENABLE_SCHEDULE=true
# SCHEDULE_START_UTC=03:30
# SCHEDULE_STOP_UTC=06:05
# SCHEDULE_TIMEZONE=UTC

# --- Architecture ---
# JIBRI_COUNT=9
# CONTROL_MACHINE_TYPE=e2-standard-4
# JVB_MACHINE_TYPE=e2-standard-16
# JIBRI_MACHINE_TYPE=e2-standard-4
# CONTROL_DISK_GB=50
# JVB_DISK_GB=50
# JIBRI_DISK_GB=30

# --- Cloudflare DNS (optional) ---
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_RECORD_NAME=meet.ingress.academy

# --- SSH (boş = avtomatik ./secrets/deploy_key) ---
# SSH_PUBLIC_KEY_PATH=
