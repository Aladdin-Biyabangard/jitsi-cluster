# ============================================================
# jitsi-deploy — yalnız bu faylı doldurun, sonra: ./deploy.sh
# ============================================================

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_ZONE=europe-west1-b
GCP_NETWORK=default

# --- Domain / SSL ---
# DNS A record: DOMAIN → meet-control public IP (deploy sonunda çap olunur)
DOMAIN=meet.ingress.academy
ADMIN_EMAIL=admin@ingress.academy

# --- Schedule (VM start/stop, xərc qənaəti) ---
# Format: HH:MM (UTC). Bakı UTC+4 → 07:30 Bakı = 03:30 UTC
ENABLE_SCHEDULE=true
SCHEDULE_START_UTC=03:30
SCHEDULE_STOP_UTC=06:05
SCHEDULE_TIMEZONE=UTC

# --- Architecture ---
JIBRI_COUNT=9
CONTROL_MACHINE_TYPE=e2-standard-4
JVB_MACHINE_TYPE=e2-standard-16
JIBRI_MACHINE_TYPE=e2-standard-4
CONTROL_DISK_GB=50
JVB_DISK_GB=50
JIBRI_DISK_GB=30

# --- Bunny.net Storage (recording upload) ---
# Storage Zone → FTP & API Access → Password = AccessKey
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_PASSWORD=your-storage-access-key
BUNNY_STORAGE_REGION=de
# Region host: de|ny|la|sg|se|br|jh|syd  →  storage.bunnycdn.com və ya {region}.storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=
# Optional: public CDN URL prefix, e.g. https://yourzone.b-cdn.net
BUNNY_UPLOAD_PATH=recordings

# --- Optional: Cloudflare DNS auto-update ---
# Boş buraxsanız DNS-i əl ilə yeniləyin
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_RECORD_NAME=meet.ingress.academy

# --- SSH ---
# Boş = avtomatik yaradılır (./secrets/deploy_key)
SSH_PUBLIC_KEY_PATH=
